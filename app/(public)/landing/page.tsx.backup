function ComparisonIcon({ val }: { val: string }) {
  if (val === "check") return <div className="flex justify-center"><Check className="w-5 h-5 text-emerald-500" /></div>
  if (val === "no") return <div className="flex justify-center"><X className="w-5 h-5 text-red-300" /></div>
  return <div className="flex justify-center"><Minus className="w-5 h-5 text-amber-400" /></div>
}

function MetricCounter({ end, suffix, prefix, label, icon: Icon }: typeof COUNTER_METRICS[number]) {
  const { value, ref } = useCountUp(end, 2000)
  return (
    <div ref={ref} className="text-center">
      <div className="w-14 h-14 rounded-2xl bg-gradient-to-br from-[#534AB7]/10 to-blue-500/10 flex items-center justify-center mx-auto mb-4">
        <Icon className="w-7 h-7 text-[#534AB7]" />
      </div>
      <p className="text-5xl font-bold bg-gradient-to-r from-[#534AB7] to-blue-500 bg-clip-text text-transparent mb-2">
        {prefix}{value}{suffix}
      </p>
      <p className="text-muted-foreground">{label}</p>
    </div>
  )
}

// ─── CSS Keyframes (injected via style tag) ──────────────────────────────────

const BLOB_STYLES = `
@keyframes blob1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(30px, -50px) scale(1.1); }
  50% { transform: translate(-20px, 20px) scale(0.9); }
  75% { transform: translate(20px, 40px) scale(1.05); }
}
@keyframes blob2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(-40px, 30px) scale(0.95); }
  50% { transform: translate(30px, -30px) scale(1.1); }
  75% { transform: translate(-10px, -40px) scale(1); }
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.5); }
}
`

