# Моя Команда — Environment Variables
# Copy this file to .env.local and fill in real values

# hh.ru API (OAuth)
HH_CLIENT_ID=your_hh_client_id_here
HH_CLIENT_SECRET=your_hh_client_secret_here
HH_REDIRECT_URI=http://localhost:3000/api/integrations/hh/callback

# Anthropic API (AI scoring)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NextAuth
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL=your_database_url_here

# DaData API (поиск компаний по ИНН/названию)
# Получить токен: https://dadata.ru/api/find-party/
NEXT_PUBLIC_DADATA_TOKEN=your_dadata_token_here

# SMTP (Timeweb) — отправка транзакционных писем (восстановление пароля и т.п.)
# Если SMTP_PASSWORD не задан — письма НЕ отправляются, только логируются.
# Это безопасно для dev-окружения.
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=noreply@mycomanda24.ru
SMTP_PASSWORD=
SMTP_FROM=noreply@mycomanda24.ru
